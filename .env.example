# kauth-konfig. Kopier til .env og fyll inn faktiske verdier.

# --- Database ----------------------------------------------------------
KAUTH_DB_PATH=./data/kauth.db

# --- Issuer og baseURL --------------------------------------------------
# I prod settes disse til den eksterne URL-en som er foran tunnelen.
KAUTH_ISSUER=https://auth.example.com
KAUTH_BASE_URL=https://auth.example.com

# --- RSA-nøkkelpar ------------------------------------------------------
# Generer med: openssl genpkey -algorithm RSA -out secrets/privateKey.pem -pkeyopt rsa_keygen_bits:2048
KAUTH_PRIVATE_KEY_PATH=./secrets/privateKey.pem
KAUTH_PUBLIC_KEY_PATH=./secrets/publicKey.pem

# --- OIDC state-cookie HMAC-secret --------------------------------------
# Generer med: openssl rand -base64 48
KAUTH_OIDC_STATE_SECRET=

# --- HTTP-port (default 8080) -------------------------------------------
KAUTH_HTTP_PORT=8083

# --- SMTP for magic-link ------------------------------------------------
# Eksempel for Resend; tilpass for andre leverandører.
KAUTH_SMTP_HOST=smtp.resend.com
KAUTH_SMTP_PORT=587
KAUTH_SMTP_USER=resend
KAUTH_SMTP_PASSWORD=
KAUTH_SMTP_FROM=noreply@example.com
KAUTH_SMTP_STARTTLS=true

# Sett til true i utviklingsoppsett uten SMTP — magic-link logges til stdout
# i stedet for å sendes.
# KAUTH_SMTP_MOCK=true

# --- Google OIDC (globale credentials, overstyres per-tjeneste i DB) -----
KAUTH_GOOGLE_CLIENT_ID=
KAUTH_GOOGLE_CLIENT_SECRET=

# --- Microsoft OIDC ----------------------------------------------------
KAUTH_MICROSOFT_CLIENT_ID=
KAUTH_MICROSOFT_CLIENT_SECRET=

# --- Lokal HTTPS-fri utvikling -----------------------------------------
# Settes til true når kauth kjøres over rein HTTP for lokal testing.
# Cookies settes da uten Secure-flagget. SKAL IKKE settes i prod.
# KAUTH_INSECURE_COOKIES=true

# --- Token-TTL (ISO 8601) ----------------------------------------------
# Per-tjeneste TTL overstyrer disse via services.access_token_ttl.
KAUTH_ACCESS_TOKEN_TTL=PT15M
KAUTH_ADMIN_TOKEN_TTL=PT8H

# --- Logging ----------------------------------------------------------
KAUTH_LOG_LEVEL=info

# --- CORS-origins for /token og /.well-known/* -------------------------
# Komma-separert, eksakt origin-match (ingen wildcard). Tom = ingen CORS-headere.
# Påkrevd for alle SPA-klienter som kaller POST /token for refresh — uten det
# stripper browseren responsen og refresh-flyten feiler stille.
# KAUTH_CORS_ORIGINS=https://app1.example.com,https://app2.example.com
